page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.content {
  padding: 40rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.icon-row {
  display: flex;
  flex-direction: row;
  gap: 40rpx;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.icon-item .iconfont {
  font-size: 48rpx;
  color: #4670e7;
}

.icon-item text {
  font-size: 24rpx;
  color: #666;
}
