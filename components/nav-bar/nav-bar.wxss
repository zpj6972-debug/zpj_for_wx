.navbar {
  width: 100%;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 10;
  background-color: #4670e7;
  box-sizing: border-box;
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  position: relative;
}

.nav-left {
  position: absolute;
  left: 20rpx;
  display: flex;
  align-items: center;
  z-index: 1;
}

.nav-icon {
  color: #fff;
  font-size: 32rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  color: #fff;
  font-size: 28rpx;
}
